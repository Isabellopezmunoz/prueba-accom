---
import { Image } from "astro:assets"
import logo from "../../assets/logo.svg"

interface Props {
  class?: string
}

const { class: className = "" } = Astro.props
---

<a
  href="/"
  class:list={["inline-flex items-center", className]}
  aria-label="Inicio"
>
  <Image src={logo} alt="" class="h-8.25 w-auto" />
</a>
