---
import FieldError from "./FieldError.astro"

interface Props {
  id: string
  name?: string
  required?: boolean
  size?: "sm" | "md"
  class?: string
}

const { id, name, required, size = "sm", class: className = "" } = Astro.props

const errorId = `${id}-error`

const boxClass = size === "md" ? "h-5 w-5" : "h-4 w-4"
const checkClass = size === "md" ? "h-3.5 w-3.5" : "h-3 w-3"
const errorPad = size === "md" ? "pl-8" : "pl-7"
---

<div class:list={["flex flex-col", className]}>
  <label
    for={id}
    class="flex items-center gap-3 text-xs leading-tight text-text"
  >
    <span class:list={["relative inline-flex shrink-0", boxClass]}>
      <input
        id={id}
        name={name ?? id}
        type="checkbox"
        required={required}
        aria-describedby={errorId}
        class:list={[
          "peer cursor-pointer appearance-none rounded-xs border border-border bg-surface checked:border-brand checked:bg-brand aria-invalid:border-brand",
          boxClass,
        ]}
      />
      <svg
        class:list={[
          "pointer-events-none absolute inset-0 m-auto hidden text-surface peer-checked:block",
          checkClass,
        ]}
        viewBox="0 0 12 12"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M2.5 6.5L5 9l4.5-5"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    </span>
    <span><slot /></span>
  </label>
  <FieldError id={errorId} class={errorPad} />
</div>
