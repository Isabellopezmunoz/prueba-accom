---
import { Image } from "astro:assets"
import checkCircle from "../../assets/icons/check-circle.svg"
import type { PricingItem, PricingIntent } from "../../types/pricing"

interface Props {
  kicker: string
  title: string
  items: PricingItem[]
  featured?: boolean
  intent?: PricingIntent
}

const { kicker, title, items, featured = false, intent } = Astro.props

const calculatorHref = intent
  ? `/calcula-tu-tarifa?intent=${intent}`
  : "/calcula-tu-tarifa"

const cardBase =
  "relative flex h-full w-full flex-col gap-10 overflow-hidden rounded-md bg-surface p-6 transition-[box-shadow,border-color] duration-200 tablet-lg:gap-6"
const cardVariant = featured
  ? "border-2 border-warn lg:shadow-card lg:hover:border-warn-soft"
  : "border border-border-softer lg:hover:shadow-[0_0_0_2px_var(--color-brand)]"
const kickerColor = featured ? "text-warn-text" : "text-brand"
---

<article class:list={["group/card", cardBase, cardVariant]}>
  {
    featured && (
      <span class="absolute right-0 top-0 rounded-bl-sm bg-warn px-3 py-1 text-2xs font-semibold leading-normal text-ink transition-colors lg:group-hover/card:bg-warn-soft">
        TOP VENTAS
      </span>
    )
  }

  <div class="flex flex-col gap-4">
    <header class="flex flex-col gap-[4.5px]">
      <span
        class:list={["text-2xs font-semibold uppercase tracking-widest", kickerColor]}
      >
        {kicker}
      </span>
      <h3 class="text-xl font-bold leading-7 text-ink">{title}</h3>
    </header>

    <ul class="flex flex-col gap-3 pb-0.5">
      {
        items.map((item) => (
          <li class="flex items-center gap-2">
            <Image src={checkCircle} alt="" class="shrink-0" />
            <span
              class:list={[
                "text-base leading-5 text-text",
                item.bold && "font-bold",
              ]}
            >
              {item.text}
            </span>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="mt-auto flex flex-col gap-2.5">
    <button
      type="button"
      data-modal-open="contact-modal"
      class="inline-flex cursor-pointer items-center justify-center rounded-sm bg-brand-soft px-6 py-3 text-md font-bold leading-normal text-ink transition-colors hover:bg-brand-faint"
    >
      Contratar
    </button>
    <a
      href={calculatorHref}
      class="inline-flex items-center justify-center rounded-sm bg-brand px-6 py-3 text-md font-bold leading-normal text-surface transition-colors hover:bg-brand-hover"
    >
      Calcula tu tarifa
    </a>
  </div>
</article>
