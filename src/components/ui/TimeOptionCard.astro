---
import type { ImageMetadata } from "astro"

interface Props {
  id: string
  name: string
  value: string
  label: string
  description: string
  icon: ImageMetadata
}

const { id, name, value, label, description, icon } = Astro.props
---

<label
  for={id}
  class="group relative flex cursor-pointer flex-col items-center gap-3 rounded-sm bg-surface p-6 text-center transition-shadow has-checked:shadow-focus md:flex-1"
>
  <input
    id={id}
    name={name}
    value={value}
    type="radio"
    class="sr-only"
  />
  <span
    class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-brand-tint"
  >
    <img src={icon.src} alt="" width="28" height="28" />
  </span>
  <span class="flex flex-col gap-1">
    <span class="text-lg font-bold leading-tight text-ink">{label}</span>
    <span class="text-base font-normal leading-snug text-text">
      {description}
    </span>
  </span>
</label>
