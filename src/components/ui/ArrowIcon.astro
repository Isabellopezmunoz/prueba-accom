---
import arrowLeft from "../../assets/icons/arrow-left.svg?raw"
import arrowRight from "../../assets/icons/arrow-right.svg?raw"

interface Props {
  direction: "left" | "right"
  class?: string
}

const { direction, class: className = "h-4 w-4" } = Astro.props

const svg = direction === "right" ? arrowRight : arrowLeft
---

<span class:list={["inline-flex shrink-0", className]} set:html={svg} />
