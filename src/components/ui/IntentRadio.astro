---
import { Image } from "astro:assets"
import type { ImageMetadata } from "astro"

interface Props {
  id: string
  name: string
  value: string
  mobileIcons: ImageMetadata[]
  desktopIcons: ImageMetadata[]
  title: string
  description: string
  recommended?: boolean
}

const {
  id,
  name,
  value,
  mobileIcons,
  desktopIcons,
  title,
  description,
  recommended = false,
} = Astro.props
---

<label
  for={id}
  class:list={[
    "relative flex h-full cursor-pointer flex-col items-center gap-4 rounded-md border-2 bg-surface p-8 text-center transition-colors hover:border-brand md:gap-2 md:rounded-sm md:p-5",
    recommended ? "border-[#DBE1FF]" : "border-transparent",
  ]}
>
  <input
    id={id}
    name={name}
    value={value}
    type="radio"
    class="sr-only"
  />

  {
    recommended && (
      <span class="absolute -top-2.5 left-1/2 inline-flex -translate-x-1/2 items-center justify-center rounded-full bg-brand px-3 py-1 text-2xs font-bold uppercase leading-none [letter-spacing:-0.5px] text-surface">
        Recomendado
      </span>
    )
  }

  <span
    class:list={[
      "inline-flex h-16 w-16 items-center justify-center rounded-full",
      recommended ? "bg-brand/10 md:bg-brand-tint" : "bg-brand-faint md:bg-surface-alt",
    ]}
  >
    <span class="flex items-center md:hidden">
      {mobileIcons.map((icon) => <Image src={icon} alt="" class="h-6 w-auto" />)}
    </span>
    <span class="hidden items-center md:flex">
      {desktopIcons.map((icon) => <Image src={icon} alt="" class="h-6 w-auto" />)}
    </span>
  </span>

  <h3 class="text-md font-semibold text-ink md:text-xl md:font-bold">
    {title}
  </h3>

  <p class="hidden text-base font-medium text-text-subtle md:block">
    {description}
  </p>
</label>
