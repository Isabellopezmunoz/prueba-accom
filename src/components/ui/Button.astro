---
interface Props {
  href?: string
  variant?: "brand"
  size?: "md" | "lg"
  type?: "button" | "submit" | "reset"
  class?: string
}

const {
  href,
  variant = "brand",
  size = "md",
  type = "button",
  class: className = "",
} = Astro.props

const base =
  "inline-flex cursor-pointer items-center justify-center rounded-sm font-semibold transition-colors"
const sizes = {
  md: "px-6 py-2 text-md leading-tight",
  lg: "w-full px-0 py-4 text-lg leading-7",
}
const variants = {
  brand: "bg-brand text-surface hover:bg-brand-hover",
}
const classes = [base, sizes[size], variants[variant], className]
---

{
  href ? (
    <a href={href} class:list={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class:list={classes}>
      <slot />
    </button>
  )
}
