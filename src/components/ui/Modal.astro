---
import { Image } from "astro:assets"
import closeIcon from "../../assets/icons/close.svg"

interface Props {
  id: string
  labelledby?: string
  class?: string
}

const { id, labelledby, class: className = "" } = Astro.props
---

<div
  id={id}
  role="dialog"
  aria-modal="true"
  aria-labelledby={labelledby}
  data-state="closed"
  class="fixed inset-0 z-100 flex items-center justify-center bg-ink/60 px-4 py-8 opacity-0 transition-opacity duration-200 ease-out data-[state=closed]:pointer-events-none data-[state=open]:opacity-100"
  data-modal
>
  <div
    class:list={[
      "relative max-h-full w-full max-w-lg scale-95 overflow-y-auto rounded-md border border-border-faint bg-surface opacity-0 shadow-hero transition-[opacity,transform] duration-200 ease-out focus:outline-none",
      "data-[state=open]:scale-100 data-[state=open]:opacity-100",
      className,
    ]}
    data-state="closed"
    data-modal-content
    tabindex="-1"
  >
    <button
      type="button"
      class="absolute right-4 top-4 inline-flex h-11 w-11 cursor-pointer items-center justify-center rounded-full text-text transition-colors hover:bg-surface-tint"
      aria-label="Cerrar"
      data-modal-close
    >
      <Image src={closeIcon} alt="" class="h-[11.67px] w-auto" />
    </button>
    <slot />
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-modal]").forEach((modal) => {
    const id = modal.id
    const closeBtn = modal.querySelector<HTMLButtonElement>("[data-modal-close]")
    const content = modal.querySelector<HTMLElement>("[data-modal-content]")

    const setState = (state: "open" | "closed") => {
      modal.dataset.state = state
      if (content) content.dataset.state = state
    }

    const open = () => {
      document.body.style.overflow = "hidden"
      requestAnimationFrame(() => setState("open"))
      content?.focus()
    }

    const close = () => {
      setState("closed")
      document.body.style.overflow = ""
      modal.dispatchEvent(new CustomEvent("modal:closed"))
    }

    closeBtn?.addEventListener("click", close)
    modal.addEventListener("click", (event) => {
      if (event.target === modal) close()
    })
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && modal.dataset.state === "open") close()
    })

    document.querySelectorAll<HTMLElement>(`[data-modal-open="${id}"]`).forEach((trigger) =>
      trigger.addEventListener("click", (event) => {
        event.preventDefault()
        open()
      })
    )

    modal.addEventListener("modal:open", open)
    modal.addEventListener("modal:close", close)
  })
</script>
