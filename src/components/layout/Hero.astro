---
import electricityIcon from "../../assets/icons/electricity.svg"
import gasIcon from "../../assets/icons/gas.svg"
import verifiedIcon from "../../assets/icons/verified-badge.svg"
import { Image } from "astro:assets"
import Badge from "../ui/Badge.astro"
import Button from "../ui/Button.astro"
import Checkbox from "../ui/Checkbox.astro"
import Input from "../ui/Input.astro"
import IntentButton from "../ui/IntentButton.astro"
import Select from "../ui/Select.astro"

const consumptionOptions = [
  { value: "morning", label: "Por la mañana" },
  { value: "afternoon", label: "Por la tarde" },
  { value: "night", label: "Por la noche" },
  { value: "all-day", label: "Durante todo el día" },
]
---

<section
  class="relative overflow-hidden px-4 pb-5 pt-3 md:pt-6 lg:px-8 lg:py-11.25"
>
  <div class="grid gap-5 lg:grid-cols-[1fr_446px] lg:gap-8 lg:items-start xl:gap-0">
    <div class="flex flex-col gap-5 pb-4 lg:max-w-192.5 lg:gap-6 lg:pb-4">
      <div class="self-start">
        <Badge>
          <span class="block md:inline">Comparador de energía</span>
          <span class="hidden md:inline">:</span>
          <span class="block md:inline">¡Ahorro garantizado!</span>
        </Badge>
      </div>

      <h1
        class="text-5xl font-extrabold leading-[1.1] text-ink lg:text-[64px] lg:leading-none"
      >
        Expertos en ahorro: <span class="text-brand">Paga menos en tu factura</span> en solo unos minutos.
      </h1>

      <p class="text-xl font-normal leading-relaxed text-text">
        Analizamos tu factura para encontrar una tarifa con la que pagarás
        menos. Sin trucos, sin permanencia.
      </p>

      <p class="flex items-center gap-3 text-md font-medium text-text">
        <Image src={verifiedIcon} alt="" class="shrink-0" />
        Gestión 100% gratuita
      </p>
    </div>

    <div class="relative">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -top-20 left-1/2 -z-10 h-96 w-96 -translate-x-1/2 rounded-full bg-brand/5 blur-3xl"
      ></div>

      <form
        id="hero-calculator-form"
        class="relative flex flex-col gap-6 rounded-md border border-border-faint bg-surface p-4 shadow-hero md:p-8 md:pb-12"
      >
        <h3 class="text-xl font-bold leading-snug text-ink md:text-2xl">
          Calcula tu mejor tarifa
        </h3>

        <fieldset class="flex flex-col gap-3">
          <legend class="mb-3 text-base font-semibold text-ink">
            ¿En qué factura quieres ahorrar?
          </legend>
          <div class="grid grid-cols-3 gap-2">
            <IntentButton
              id="intent-luz"
              name="intent"
              value="luz"
              label="Luz"
              icons={[electricityIcon]}
            />
            <IntentButton
              id="intent-gas"
              name="intent"
              value="gas"
              label="Gas"
              icons={[gasIcon]}
            />
            <IntentButton
              id="intent-luz-gas"
              name="intent"
              value="luz-gas"
              label="Luz+gas"
              icons={[electricityIcon, gasIcon]}
            />
          </div>
        </fieldset>

        <Select
          id="consumption"
          label="¿Cuándo es tu mayor consumo?"
          options={consumptionOptions}
          placeholder="Selecciona tu consumo"
        />

        <div class="grid grid-cols-2 gap-4">
          <Input
            id="phone"
            label="Teléfono"
            type="tel"
            placeholder="Teléfono"
            inputmode="tel"
            autocomplete="tel"
            pattern="[+]?[0-9 ]{9,}"
            required
          />
          <Input
            id="postal-code"
            label="Código postal"
            type="text"
            placeholder="C.P"
            inputmode="numeric"
            pattern="[0-9]{5}"
            autocomplete="postal-code"
          />
        </div>

        <Checkbox id="privacy" required>
          He leído y acepto la <a href="/politica-de-privacidad" class="underline"><span class="lg:hidden">Política de Privacidad</span><span class="hidden lg:inline">Política de Protección de Datos</span></a>
        </Checkbox>

        <Button type="submit" size="lg">Calcular</Button>
      </form>
    </div>
  </div>
</section>

<script>
  import { setupInlineValidation } from "../../scripts/inline-validation"

  const form = document.getElementById("hero-calculator-form") as HTMLFormElement | null
  if (form) {
    setupInlineValidation(form)

    let lastResultStatus: "success" | "error" | null = null

    form.addEventListener("submit", (event) => {
      event.preventDefault()
      const modal = document.getElementById("contact-modal")
      if (!modal) return

      const status: "success" | "error" =
        Math.random() < 0.8 ? "success" : "error"
      lastResultStatus = status
      form.dataset.active = "true"
      modal.dispatchEvent(
        new CustomEvent("modal:open-result", {
          detail: { status, source: "hero" },
        })
      )
      modal.dispatchEvent(new Event("modal:open"))
    })

    const modal = document.getElementById("contact-modal")

    modal?.addEventListener("modal:closed", () => {
      if (form.dataset.active !== "true") return
      if (lastResultStatus === "success") form.reset()
      lastResultStatus = null
      delete form.dataset.active
    })

    modal?.addEventListener("modal:retry", () => {
      if (form.dataset.active !== "true") return
      modal.dispatchEvent(new Event("modal:close"))
      form.requestSubmit()
    })
  }
</script>
