---
import { Image } from "astro:assets"
import phoneCall from "../../assets/icons/phone-call.svg"
import phone from "../../assets/icons/phone.svg"
import checkLg from "../../assets/icons/check-circle-lg.svg"
import errorTriangle from "../../assets/icons/error-triangle.svg"
import Checkbox from "../ui/Checkbox.astro"
import FieldError from "../ui/FieldError.astro"
import Modal from "../ui/Modal.astro"
---

<Modal id="contact-modal" labelledby="contact-modal-title">
  <div data-contact-form class="flex flex-col gap-5 p-5 md:gap-7.5 md:p-10">
    <header class="flex flex-col items-start gap-2 pr-12 text-left md:items-center md:pr-0 md:text-center">
      <h2
        id="contact-modal-title"
        class="text-2xl font-bold leading-tight text-ink md:text-3xl md:leading-9"
      >
        Contacta con un experto
      </h2>
      <p class="text-base text-text md:text-md">
        Estamos aquí para optimizar tu consumo energético.
      </p>
    </header>

    <div class="flex flex-col items-center gap-3 rounded-md bg-brand-tint p-4 md:gap-4 md:p-6">
      <span
        class="inline-flex h-7 w-10 items-center justify-center rounded-full bg-info shadow-nav md:h-8.5 md:w-12"
      >
        <Image src={phoneCall} alt="" class="h-4.5 w-auto" />
      </span>
      <div class="flex flex-col items-center gap-1 text-center">
        <span class="text-base font-bold uppercase tracking-widest text-brand">
          Atención directa
        </span>
        <p class="font-display text-xl font-bold text-ink md:text-2xl">
          Llámanos ahora al <a href="tel:900000000" class="whitespace-nowrap text-brand">900 000 000</a>
        </p>
      </div>
    </div>

    <div class="flex items-center gap-4">
      <span class="h-px flex-1 bg-border-soft"></span>
      <span class="text-sm text-text-subtle">o</span>
      <span class="h-px flex-1 bg-border-soft"></span>
    </div>

    <div class="flex flex-col items-center gap-1 text-center">
      <h3 class="font-display text-base font-bold text-ink md:text-lg">O te llamamos nosotros</h3>
      <p class="text-sm font-medium text-accent md:text-base">
        Sin esperas y gratuito
      </p>
    </div>

    <form class="flex flex-col gap-4" data-contact-submit>
      <div class="flex flex-col gap-1.5">
        <div class="flex flex-col gap-3 md:flex-row">
          <label class="relative flex-1">
            <span class="sr-only">Tu número de teléfono</span>
            <Image
              src={phone}
              alt=""
              class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2"
            />
            <input
              id="contact-phone"
              type="tel"
              name="phone"
              inputmode="tel"
              autocomplete="tel"
              pattern="[+]?[0-9 ]{9,}"
              required
              placeholder="Tu número de teléfono"
              aria-describedby="contact-phone-error"
              class="h-13 w-full rounded-sm border border-border-soft bg-surface pl-11 pr-4 text-base text-ink placeholder:text-text-muted focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/20 aria-invalid:border-brand"
            />
          </label>
          <button
            type="submit"
            class="inline-flex h-13 cursor-pointer items-center justify-center rounded-sm bg-brand px-6 text-lg font-bold text-surface transition-colors hover:bg-brand-hover"
          >
            Llamadme
          </button>
        </div>
        <FieldError id="contact-phone-error" />
      </div>
      <Checkbox id="contact-privacy" required>
        He leído y acepto la <a href="/politica-de-privacidad" class="text-brand underline transition-colors hover:text-brand-hover">política de privacidad</a>.
      </Checkbox>
    </form>
  </div>

  <div
    data-contact-success
    hidden
    class="flex flex-col items-center gap-6 p-6 text-center md:p-10"
  >
    <span
      class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-accent/10"
    >
      <Image src={checkLg} alt="" class="h-10.5 w-auto" />
    </span>
    <div class="flex flex-col gap-4">
      <h2 class="text-2xl font-bold text-ink">¡Solicitud recibida con éxito!</h2>
      <p class="text-base leading-relaxed text-text">
        Estamos analizando las mejores tarifas para ti.<br />
        Un experto de Ahorrarenenergía te contactará para informarte.
      </p>
    </div>
  </div>

  <div
    data-contact-error
    hidden
    class="flex flex-col items-center gap-6 p-6 text-center md:p-10"
  >
    <span
      class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-error-soft"
    >
      <Image src={errorTriangle} alt="" class="h-7.125 w-8.25" />
    </span>
    <div class="flex flex-col gap-3">
      <h2 class="text-2xl font-bold text-ink">¡Ups! Algo ha salido mal</h2>
      <p class="text-md text-text">
        Hemos tenido un problema técnico al enviar tus datos.<br />
        Por favor, inténtalo de nuevo.
      </p>
    </div>
    <button
      type="button"
      data-contact-retry
      data-source-only="calculator hero"
      hidden
      class="inline-flex cursor-pointer items-center justify-center rounded-sm bg-brand px-10 py-4 text-lg font-bold text-surface shadow-cta transition-colors hover:bg-brand-hover"
    >
      Reintentar
    </button>
    <p data-source-only="calculator hero" hidden class="text-md text-text-subtle">
      ¿Prefieres que te llamemos? <a href="tel:900000000" class="font-semibold text-brand">900 000 000</a>
    </p>
  </div>
</Modal>

<script>
  import { setupInlineValidation } from "../../scripts/inline-validation"

  const modal = document.getElementById("contact-modal")
  if (modal) {
    const formView = modal.querySelector<HTMLElement>("[data-contact-form]")
    const successView = modal.querySelector<HTMLElement>("[data-contact-success]")
    const errorView = modal.querySelector<HTMLElement>("[data-contact-error]")
    const form = modal.querySelector<HTMLFormElement>("[data-contact-submit]")
    const content = modal.querySelector<HTMLElement>("[data-modal-content]")

    if (form) setupInlineValidation(form)

    const showOnly = (view: HTMLElement | null) => {
      ;[formView, successView, errorView].forEach((current) => {
        if (current) current.hidden = current !== view
      })
      content?.classList.toggle("border", view === errorView)
      content?.classList.toggle("border-error", view === errorView)
    }

    form?.addEventListener("submit", (event) => {
      event.preventDefault()
      const success = Math.random() < 0.8
      showOnly(success ? successView : errorView)
    })

    modal.addEventListener("modal:open-result", (event) => {
      const detail = (event as CustomEvent<{
        status: "success" | "error"
        source?: string
      }>).detail
      modal.querySelectorAll<HTMLElement>("[data-source-only]").forEach((el) => {
        const allowed = (el.dataset.sourceOnly ?? "").split(" ")
        el.hidden = !detail?.source || !allowed.includes(detail.source)
      })
      showOnly(detail?.status === "error" ? errorView : successView)
    })

    modal
      .querySelector<HTMLButtonElement>("[data-contact-retry]")
      ?.addEventListener("click", () => {
        modal.dispatchEvent(new Event("modal:retry"))
      })

    modal.addEventListener("modal:closed", () => {
      form?.reset()
      showOnly(formView)
    })
  }
</script>
