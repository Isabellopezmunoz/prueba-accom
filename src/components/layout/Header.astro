---
import { Image } from "astro:assets"
import menuIcon from "../../assets/menu-rounded.svg"
import Button from "../ui/Button.astro"
import Logo from "../ui/Logo.astro"

const links = [
  { href: "#calcula", label: "Calcula tu tarifa" },
  { href: "#ofertas", label: "Ofertas" },
]
---

<header
  class="sticky top-0 z-50 w-full bg-surface-glass shadow-nav backdrop-blur-[20px]"
>
  <nav
    class="flex items-center justify-between p-4 md:px-8"
    aria-label="Principal"
  >
    <Logo />

    <button
      type="button"
      class="-m-3 p-3 md:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-nav"
      data-menu-toggle
    >
      <Image src={menuIcon} alt="" class="h-12 w-12" />
    </button>

    <div class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-md font-medium leading-tight text-text transition-colors hover:text-brand"
          >
            {link.label}
          </a>
        ))
      }
      <Button href="#contactar">Contactar</Button>
    </div>
  </nav>

  <div
    id="mobile-nav"
    class="hidden border-t border-border-faint bg-surface-glass backdrop-blur-[20px] md:hidden"
    data-menu-panel
  >
    <ul class="flex flex-col gap-4 p-4">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="block rounded-sm px-3 py-2 text-md font-medium leading-tight text-text transition-colors hover:bg-brand-tint hover:text-brand active:bg-brand-tint active:text-brand"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <Button href="#contactar" class="w-full">Contactar</Button>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]")
  const panel = document.querySelector<HTMLElement>("[data-menu-panel]")

  if (toggle && panel) {
    toggle.addEventListener("click", () => {
      const open = panel.classList.toggle("hidden") === false
      toggle.setAttribute("aria-expanded", String(open))
      toggle.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú")
    })

    panel.querySelectorAll("a").forEach((a) =>
      a.addEventListener("click", () => {
        panel.classList.add("hidden")
        toggle.setAttribute("aria-expanded", "false")
        toggle.setAttribute("aria-label", "Abrir menú")
      })
    )
  }
</script>
