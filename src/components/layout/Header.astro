---
import Logo from "../ui/Logo.astro"
import MobileNav from "../ui/MobileNav.astro"

const links = [
  { href: "/calcula-tu-tarifa", label: "Calcula tu tarifa" },
  { href: "/#ofertas", label: "Ofertas" },
]

const currentPath = Astro.url.pathname
const isActive = (href: string) =>
  href.startsWith("/") && (currentPath === href || currentPath === `${href}/`)
---

<header
  class="sticky top-0 z-50 w-full bg-surface-glass shadow-nav backdrop-blur-[20px]"
>
  <nav
    class="flex items-center justify-between p-4 md:px-8"
    aria-label="Principal"
  >
    <Logo />

    <MobileNav variant="trigger" links={links} currentPath={currentPath} />

    <div class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            data-reset-calculator={
              link.href === "/calcula-tu-tarifa" ? "true" : undefined
            }
            class:list={[
              "text-md font-medium leading-tight transition-colors hover:text-brand",
              isActive(link.href) ? "text-brand" : "text-text",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <button
        type="button"
        data-modal-open="contact-modal"
        class="inline-flex cursor-pointer items-center justify-center rounded-sm bg-brand px-6 py-2 text-md font-semibold leading-tight text-surface transition-colors hover:bg-brand-hover"
      >
        Contactar
      </button>
    </div>
  </nav>

  <MobileNav variant="panel" links={links} currentPath={currentPath} />
</header>

<script>
  document
    .querySelectorAll<HTMLAnchorElement>("[data-reset-calculator]")
    .forEach((link) =>
      link.addEventListener("click", () => {
        sessionStorage.removeItem("calculator-state")
      })
    )
</script>
