---
import Logo from "../ui/Logo.astro"

const links = [
  { label: "Aviso Legal", href: "/aviso-legal" },
  { label: "Política de Privacidad", href: "/politica-de-privacidad" },
  { label: "Cookies", href: "/cookies" },
]
---

<footer class="bg-surface-alt px-8 py-12">
  <div
    class="flex flex-col items-center gap-5 md:flex-row md:justify-between md:gap-6"
  >
    <Logo />
    <nav>
      <ul class="flex items-center justify-center gap-6">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm font-normal text-text/80 transition-colors hover:text-brand active:text-brand"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</footer>
