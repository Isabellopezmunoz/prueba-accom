---
import PricingCard from "../ui/PricingCard.astro"

const cards = [
  {
    tab: "luz",
    intent: "luz" as const,
    kicker: "precio fijo",
    title: "Tarifa fija de luz",
    items: [
      { text: "Mantenemos el precio durante 5 años.", bold: true },
      { text: "Precio fijo 12 meses" },
      { text: "20 cts €/l en tus repostajes." },
    ],
  },
  {
    tab: "luz",
    intent: "luz" as const,
    desktopOnly: true,
    kicker: "precio fijo",
    title: "Tarifa fija de luz",
    items: [
      { text: "Mantenemos el precio durante 5 años.", bold: true },
      { text: "Precio fijo 12 meses" },
      { text: "20 cts €/l en tus repostajes." },
    ],
  },
  {
    tab: "dual",
    intent: "luz-gas" as const,
    kicker: "ahorro máximo",
    title: "Tarifa de luz y gas",
    featured: true,
    items: [
      { text: "1 mes gratis de consumo de luz para siempre.", bold: true },
      { text: "10% dto. en el consumo de luz durante 1 año." },
      { text: "20% dto. en el de gas durante 1 año." },
    ],
  },
  {
    tab: "gas",
    intent: "gas" as const,
    kicker: "precio fijo",
    title: "Tarifa fija de gas",
    items: [
      { text: "Mantenemos el precio durante 5 años.", bold: true },
      { text: "Precio fijo 12 meses" },
      { text: "20 cts €/l en tus repostajes." },
    ],
  },
]

const tabs = [
  { value: "luz", label: "Tarifas luz" },
  { value: "dual", label: "Tarifa dual" },
  { value: "gas", label: "Tarifas gas" },
]
---

<section class="bg-surface-tint px-4 py-15 md:px-8">
  <div class="mx-auto flex max-w-304 flex-col gap-6 md:gap-12">
    <h2 class="text-center text-4xl font-bold leading-none text-ink">
      Las mejores tarifas de luz y gas para ahorrar en tu factura
    </h2>

    <div
      role="tablist"
      aria-label="Tipo de tarifa"
      class="relative mx-auto flex h-13 w-90 items-center justify-between gap-2.5 rounded-pill bg-surface px-2 py-1.5 shadow-brand tablet-lg:hidden"
      data-pricing-tabs
    >
      <span
        aria-hidden="true"
        class="pointer-events-none absolute left-2 top-1.5 bottom-1.5 rounded-pill bg-brand shadow-tab transition-[transform,width] duration-500 ease-[cubic-bezier(0.32,0.72,0,1)]"
        data-tabs-indicator
      ></span>
      {
        tabs.map((tab, index) => (
          <button
            type="button"
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            data-tab={tab.value}
            class="relative z-10 flex-1 cursor-pointer whitespace-nowrap rounded-pill px-2 py-2 text-md font-semibold leading-tight text-ink transition-colors duration-300 ease-out aria-selected:text-surface aria-selected:leading-snug"
          >
            {tab.label}
          </button>
        ))
      }
    </div>

    <div
      class="-mx-4 flex snap-x snap-mandatory items-stretch gap-4 overflow-x-auto scroll-smooth px-[10%] pb-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden tablet-lg:mx-0 tablet-lg:grid tablet-lg:grid-cols-4 tablet-lg:gap-6 tablet-lg:overflow-visible tablet-lg:px-0 tablet-lg:pb-0"
      data-pricing-track
    >
      {
        cards.map((card) => (
          <div
            data-card-tab={card.tab}
            data-desktop-only={card.desktopOnly ? "true" : undefined}
            class:list={[
              "flex w-[80%] max-w-md shrink-0 snap-center transition-[transform,opacity] duration-300 ease-out max-tablet-lg:[&:not([data-active=true])]:opacity-60 max-tablet-lg:[&:not([data-active=true])]:scale-95 tablet-lg:w-auto tablet-lg:max-w-none",
              card.desktopOnly && "hidden tablet-lg:flex",
            ]}
          >
            <PricingCard {...card} />
          </div>
        ))
      }
    </div>

    <div
      class="flex justify-center gap-2 tablet-lg:hidden"
      role="tablist"
      aria-label="Paginación de tarifas"
      data-pricing-bullets
    ></div>
  </div>
</section>

<script>
  const tablist = document.querySelector<HTMLElement>("[data-pricing-tabs]")
  const track = document.querySelector<HTMLElement>("[data-pricing-track]")
  if (tablist && track) {
    const tabs = tablist.querySelectorAll<HTMLButtonElement>("[role=tab]")
    const indicator = tablist.querySelector<HTMLElement>("[data-tabs-indicator]")
    const cards = track.querySelectorAll<HTMLElement>(
      "[data-card-tab]:not([data-desktop-only])"
    )

    const tabValues = Array.from(tabs).map((tab) => tab.dataset.tab ?? "")
    const cardTabs = Array.from(cards).map((card) => card.dataset.cardTab ?? "")

    const bulletsContainer = document.querySelector<HTMLElement>(
      "[data-pricing-bullets]"
    )

    const bullets: HTMLButtonElement[] = []
    if (bulletsContainer) {
      cards.forEach((card, index) => {
        const bullet = document.createElement("button")
        bullet.type = "button"
        bullet.role = "tab"
        bullet.setAttribute("aria-label", `Ir a tarifa ${index + 1}`)
        bullet.dataset.bulletIndex = String(index)
        bullet.className =
          "h-2.5 w-2.5 cursor-pointer rounded-full bg-border-soft transition-all aria-selected:w-6 aria-selected:bg-brand"
        bullet.addEventListener("click", () => {
          card.scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" })
        })
        bulletsContainer.appendChild(bullet)
        bullets.push(bullet)
      })
    }

    const setActiveIndex = (index: number) => {
      bullets.forEach((bullet, bulletIndex) => {
        bullet.setAttribute("aria-selected", bulletIndex === index ? "true" : "false")
      })
    }

    const moveIndicator = (target: HTMLElement) => {
      if (!indicator) return
      const tablistRect = tablist.getBoundingClientRect()
      const targetRect = target.getBoundingClientRect()
      indicator.style.width = `${targetRect.width}px`
      indicator.style.transform = `translateX(${targetRect.left - tablistRect.left - 8}px)`
    }

    const setActiveTab = (value: string) => {
      tabs.forEach((tab) => {
        const active = tab.dataset.tab === value
        tab.setAttribute("aria-selected", active ? "true" : "false")
        if (active) moveIndicator(tab)
      })
      cards.forEach((card, cardIndex) => {
        const active = card.dataset.cardTab === value
        if (active) {
          card.dataset.active = "true"
          setActiveIndex(cardIndex)
        } else {
          delete card.dataset.active
        }
      })
    }

    const initial = tablist.querySelector<HTMLElement>('[role=tab][aria-selected=true]')
    if (initial) {
      requestAnimationFrame(() => moveIndicator(initial))
      const initialValue = initial.dataset.tab ?? ""
      cards.forEach((card, cardIndex) => {
        if (card.dataset.cardTab === initialValue) {
          card.dataset.active = "true"
          setActiveIndex(cardIndex)
        }
      })
    }
    window.addEventListener("resize", () => {
      const current = tablist.querySelector<HTMLElement>('[role=tab][aria-selected=true]')
      if (current) moveIndicator(current)
    })

    tabs.forEach((tab) =>
      tab.addEventListener("click", () => {
        const value = tab.dataset.tab ?? ""
        setActiveTab(value)
        const cardIndex = cardTabs.indexOf(value)
        if (cardIndex >= 0)
          cards[cardIndex]?.scrollIntoView({
            behavior: "smooth",
            inline: "center",
            block: "nearest",
          })
      })
    )

    let scrollFrame = 0
    track.addEventListener("scroll", () => {
      if (scrollFrame) return
      scrollFrame = requestAnimationFrame(() => {
        scrollFrame = 0
        const trackRect = track.getBoundingClientRect()
        const center = trackRect.left + trackRect.width / 2
        let closestIndex = 0
        let closestDistance = Infinity
        cards.forEach((card, index) => {
          const cardRect = card.getBoundingClientRect()
          const distance = Math.abs(cardRect.left + cardRect.width / 2 - center)
          if (distance < closestDistance) {
            closestDistance = distance
            closestIndex = index
          }
        })
        const value = cardTabs[closestIndex]
        if (value && tabValues.includes(value)) setActiveTab(value)
      })
    })
  }
</script>
