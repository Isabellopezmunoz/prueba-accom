---
import Layout from "../layouts/Layout.astro"
import Header from "../components/layout/Header.astro"
import Footer from "../components/layout/Footer.astro"
import ContactModal from "../components/layout/ContactModal.astro"
import ResultModal from "../components/layout/ResultModal.astro"
import TariffCalculator from "../components/wizard/TariffCalculator.astro"
---

<Layout title="Calcula tu ahorro · Ahorrar Energía">
  <Header />

  <main class="flex-1 bg-surface-alt px-4 py-8 md:px-8 md:py-20 lg:px-48 lg:py-22.5">
    <div class="mx-auto flex w-full max-w-4xl flex-col gap-9">
      <TariffCalculator />
    </div>
  </main>

  <Footer />
  <ContactModal />
  <ResultModal />
</Layout>
