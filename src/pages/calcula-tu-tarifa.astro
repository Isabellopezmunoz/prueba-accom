---
import Layout from "../layouts/Layout.astro"
import Header from "../components/layout/Header.astro"
import Footer from "../components/layout/Footer.astro"
import ContactModal from "../components/layout/ContactModal.astro"
import IntentRadio from "../components/ui/IntentRadio.astro"
import ApplianceCard from "../components/ui/ApplianceCard.astro"
import TimeOptionCard from "../components/ui/TimeOptionCard.astro"
import Input from "../components/ui/Input.astro"
import Checkbox from "../components/ui/Checkbox.astro"
import ArrowIcon from "../components/ui/ArrowIcon.astro"
import intentBulb from "../assets/icons/intent-bulb.svg"
import intentFan from "../assets/icons/intent-fan.svg"
import intentBolt from "../assets/icons/intent-bolt.svg"
import intentFlame from "../assets/icons/intent-flame.svg"
import fridgeIcon from "../assets/icons/appliance-fridge.svg"
import microwaveIcon from "../assets/icons/appliance-microwave.svg"
import ovenIcon from "../assets/icons/appliance-oven.svg"
import washerIcon from "../assets/icons/appliance-washer.svg"
import dishwasherIcon from "../assets/icons/appliance-dishwasher.svg"
import acIcon from "../assets/icons/appliance-ac.svg"
import morningIcon from "../assets/icons/time-morning.svg"
import eveningIcon from "../assets/icons/time-evening.svg"
import allDayIcon from "../assets/icons/time-allday.svg"
import phoneIcon from "../assets/icons/phone.svg"
import locationIcon from "../assets/icons/location-pin.svg"

const intents = [
  {
    mobileIcons: [intentBulb],
    desktopIcons: [intentBolt],
    title: "Solo Luz",
    description: "Electricidad para tu hogar o negocio",
    value: "luz",
  },
  {
    mobileIcons: [intentBolt],
    desktopIcons: [intentBolt, intentFlame],
    title: "Luz + Gas",
    description: "Máximo ahorro combinando suministros",
    value: "luz-gas",
    recommended: true,
  },
  {
    mobileIcons: [intentFan],
    desktopIcons: [intentFlame],
    title: "Solo Gas",
    description: "Calefacción y agua caliente",
    value: "gas",
  },
]

const appliances = [
  { id: "appliance-fridge", value: "fridge", label: "Frigorífico", icon: fridgeIcon },
  { id: "appliance-microwave", value: "microwave", label: "Microondas", icon: microwaveIcon },
  { id: "appliance-oven", value: "oven", label: "Horno", icon: ovenIcon },
  { id: "appliance-washer", value: "washer", label: "Lavadora", icon: washerIcon },
  { id: "appliance-dishwasher", value: "dishwasher", label: "Lavavajillas", icon: dishwasherIcon },
  { id: "appliance-ac", value: "ac", label: "Aire acondicionado", icon: acIcon },
]

const timeOptions = [
  {
    id: "time-morning",
    value: "morning",
    label: "Por la mañana",
    description: "Ideal si teletrabajas o tienes mañanas activas.",
    icon: morningIcon,
  },
  {
    id: "time-evening",
    value: "evening",
    label: "Tarde-Noche",
    description: "Cuando la actividad comienza al llegar del trabajo.",
    icon: eveningIcon,
  },
  {
    id: "time-allday",
    value: "allday",
    label: "Todo el día",
    description: "Siempre hay alguien en casa o consumo constante.",
    icon: allDayIcon,
  },
]
---

<Layout title="Calcula tu ahorro · Ahorrar Energía">
  <Header />

  <main class="flex flex-1 items-center bg-surface-alt px-4 py-15 md:px-48 md:py-22.5">
    <div class="mx-auto flex w-full max-w-4xl flex-col gap-9">
      <h1
        class="text-center text-3xl font-bold leading-tight text-ink md:text-5xl md:leading-none"
      >
        ¿Qué quieres empezar a ahorrar hoy?
      </h1>

      <form
        id="calculator-form"
        class="flex flex-col gap-8 md:gap-12"
        novalidate
      >
        <section
          data-step="1"
          aria-labelledby="step-1-label"
          class="flex flex-col gap-6 [[hidden]]:hidden"
        >
          <p
            id="step-1-label"
            class="w-full text-center text-md font-medium text-text md:text-2xl md:leading-none"
          >
            Selecciona tu tipo de suministro para personalizar tu oferta
          </p>
          <div class="grid w-full gap-6 md:grid-cols-3">
            {
              intents.map((intent) => (
                <IntentRadio
                  id={`intent-${intent.value}`}
                  name="intent"
                  value={intent.value}
                  mobileIcons={intent.mobileIcons}
                  desktopIcons={intent.desktopIcons}
                  title={intent.title}
                  description={intent.description}
                  recommended={intent.recommended}
                />
              ))
            }
          </div>
        </section>

        <section
          data-step="2"
          hidden
          aria-labelledby="step-2-label"
          class="flex flex-col gap-6 [[hidden]]:hidden"
        >
          <p
            id="step-2-label"
            class="w-full text-center text-md font-medium text-text md:text-2xl md:leading-none"
          >
            ¿Qué electrodomésticos usas?
          </p>
          <div class="grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-6">
            {
              appliances.map((appliance) => (
                <ApplianceCard
                  id={appliance.id}
                  name="appliances"
                  value={appliance.value}
                  label={appliance.label}
                  icon={appliance.icon}
                />
              ))
            }
          </div>

          <div class="flex items-center justify-between gap-4">
            <button
              type="button"
              data-action="back"
              class="inline-flex items-center gap-2 rounded-sm px-6 py-3 text-base font-semibold text-text-slate transition-colors hover:text-ink"
            >
              <ArrowIcon direction="left" />
              Atrás
            </button>
            <button
              type="button"
              data-action="next"
              class="inline-flex items-center gap-3 rounded-sm bg-brand px-10 py-4 text-lg font-bold text-surface shadow-cta transition-colors hover:bg-brand-hover disabled:cursor-not-allowed disabled:opacity-50"
            >
              Siguiente
              <ArrowIcon direction="right" />
            </button>
          </div>
        </section>

        <section
          data-step="3"
          hidden
          aria-labelledby="step-3-label"
          class="flex flex-col gap-6 [[hidden]]:hidden"
        >
          <p
            id="step-3-label"
            class="w-full text-center text-md font-medium text-text md:text-2xl md:leading-none"
          >
            ¿Cuándo haces un mayor uso de la energía?
          </p>
          <div class="flex flex-col gap-4 md:flex-row md:gap-6">
            {timeOptions.map((option) => <TimeOptionCard {...option} name="usage-time" />)}
          </div>

          <div class="flex items-center justify-between gap-4">
            <button
              type="button"
              data-action="back"
              class="inline-flex items-center gap-2 rounded-sm px-6 py-3 text-base font-semibold text-text-slate transition-colors hover:text-ink"
            >
              <ArrowIcon direction="left" />
              Atrás
            </button>
          </div>
        </section>

        <section
          data-step="4"
          hidden
          aria-labelledby="step-4-label"
          class="flex flex-col gap-6 [[hidden]]:hidden"
        >
          <header id="step-4-label" class="flex flex-col gap-2 text-center">
            <p class="text-2xl font-bold leading-none text-text">
              Estamos calculando tu ahorro.
            </p>
            <p class="text-md font-semibold leading-normal text-text">
              Completa los detalles finales para recibir tu estudio gratuito.
            </p>
          </header>

          <div class="grid gap-4 md:grid-cols-2 md:gap-6">
            <Input
              id="calc-phone"
              label="Teléfono de contacto"
              type="tel"
              placeholder="600 000 000"
              inputmode="tel"
              autocomplete="tel"
              icon={phoneIcon}
              required
            />
            <Input
              id="calc-postal-code"
              label="Código postal"
              type="text"
              placeholder="28001"
              inputmode="numeric"
              pattern="[0-9]{5}"
              autocomplete="postal-code"
              icon={locationIcon}
            />
          </div>

          <Checkbox id="calc-privacy" required shape="square">
            He leído y acepto la <a href="/politica-de-privacidad" class="text-brand underline">Política de Privacidad</a> y consiento el tratamiento de mis datos.
          </Checkbox>

          <div class="flex justify-center">
            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-sm bg-brand px-10 py-4 text-lg font-bold text-surface shadow-cta transition-colors hover:bg-brand-hover"
            >
              Calcular
            </button>
          </div>
        </section>

      </form>
    </div>
  </main>

  <Footer />
  <ContactModal />
</Layout>

<script>
  import { setupInlineValidation } from "../scripts/inline-validation"

  const form = document.getElementById("calculator-form") as HTMLFormElement | null
  if (form) {
    setupInlineValidation(form)

    const steps = Array.from(
      form.querySelectorAll<HTMLElement>("section[data-step]")
    )
    const STORAGE_KEY = "calculator-state"
    let currentIndex = 0

    const showStep = (index: number) => {
      steps.forEach((step, i) => {
        step.hidden = i !== index
      })
      currentIndex = index
      window.scrollTo({ top: 0, behavior: "smooth" })
      saveState()
    }

    const saveState = () => {
      const data = new FormData(form)
      const state = {
        intent: data.get("intent"),
        appliances: data.getAll("appliances"),
        usageTime: data.get("usage-time"),
        phone: (form.elements.namedItem("calc-phone") as HTMLInputElement | null)
          ?.value,
        postalCode: (form.elements.namedItem("calc-postal-code") as HTMLInputElement | null)
          ?.value,
        privacy: (form.elements.namedItem("calc-privacy") as HTMLInputElement | null)
          ?.checked,
        currentIndex,
      }
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify(state))
    }

    const restoreState = () => {
      const raw = sessionStorage.getItem(STORAGE_KEY)
      if (!raw) return
      try {
        const state = JSON.parse(raw)
        if (state.intent) {
          const intent = form.querySelector<HTMLInputElement>(
            `input[name='intent'][value='${state.intent}']`
          )
          if (intent) intent.checked = true
        }
        if (Array.isArray(state.appliances)) {
          state.appliances.forEach((value: string) => {
            const checkbox = form.querySelector<HTMLInputElement>(
              `input[name='appliances'][value='${value}']`
            )
            if (checkbox) checkbox.checked = true
          })
        }
        if (state.usageTime) {
          const usage = form.querySelector<HTMLInputElement>(
            `input[name='usage-time'][value='${state.usageTime}']`
          )
          if (usage) usage.checked = true
        }
        const phone = form.elements.namedItem("calc-phone") as HTMLInputElement | null
        if (phone && state.phone) phone.value = state.phone
        const postal = form.elements.namedItem("calc-postal-code") as HTMLInputElement | null
        if (postal && state.postalCode) postal.value = state.postalCode
        const privacy = form.elements.namedItem("calc-privacy") as HTMLInputElement | null
        if (privacy && state.privacy) privacy.checked = true
        if (typeof state.currentIndex === "number") {
          showStep(Math.max(0, Math.min(steps.length - 1, state.currentIndex)))
        }
      } catch {
        sessionStorage.removeItem(STORAGE_KEY)
      }
    }

    restoreState()
    form.addEventListener("change", saveState)
    form.addEventListener("input", saveState)

    const advanceFromStep1 = () => {
      const intent = form.querySelector<HTMLInputElement>(
        "input[name='intent']:checked"
      )
      if (intent) {
        showStep(1)
      }
    }

    const advanceFromStep3 = () => {
      const usage = form.querySelector<HTMLInputElement>(
        "input[name='usage-time']:checked"
      )
      if (usage) {
        showStep(3)
      }
    }

    form.addEventListener("change", (event) => {
      const target = event.target as HTMLInputElement
      if (target.name === "intent" && currentIndex === 0) {
        advanceFromStep1()
      }
      if (target.name === "usage-time" && currentIndex === 2) {
        advanceFromStep3()
      }
    })

    form.querySelectorAll<HTMLButtonElement>("[data-action='back']").forEach(
      (button) =>
        button.addEventListener("click", () => {
          if (currentIndex > 0) showStep(currentIndex - 1)
        })
    )

    form.querySelectorAll<HTMLButtonElement>("[data-action='next']").forEach(
      (button) =>
        button.addEventListener("click", () => {
          if (currentIndex < steps.length - 1) showStep(currentIndex + 1)
        })
    )

    let lastResultStatus: "success" | "error" | null = null

    form.addEventListener("submit", (event) => {
      event.preventDefault()

      const modal = document.getElementById("contact-modal")
      if (!modal) return

      const status: "success" | "error" =
        Math.random() < 0.8 ? "success" : "error"
      lastResultStatus = status
      form.dataset.active = "true"
      modal.dispatchEvent(
        new CustomEvent("modal:open-result", {
          detail: { status, source: "calculator" },
        })
      )
      modal.dispatchEvent(new Event("modal:open"))
    })

    const modal = document.getElementById("contact-modal")

    modal?.addEventListener("modal:closed", () => {
      if (form.dataset.active !== "true") return
      if (lastResultStatus === "success") {
        sessionStorage.removeItem(STORAGE_KEY)
        window.location.href = "/"
      }
      lastResultStatus = null
      delete form.dataset.active
    })

    modal?.addEventListener("modal:retry", () => {
      if (form.dataset.active !== "true") return
      modal.dispatchEvent(new Event("modal:close"))
      form.requestSubmit()
    })
  }
</script>
