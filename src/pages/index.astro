---
import Layout from "../layouts/Layout.astro"
import Header from "../components/layout/Header.astro"
import ContactModal from "../components/layout/ContactModal.astro"
import ResultModal from "../components/layout/ResultModal.astro"
import Hero from "../components/layout/Hero.astro"
import OffersSection from "../components/layout/OffersSection.astro"
import PricingSection from "../components/layout/PricingSection.astro"
import Footer from "../components/layout/Footer.astro"
---

<Layout
  title="Ahorrar Energía · Compara tarifas de luz y gas"
  description="Encuentra la tarifa de luz y gas que mejor se adapta a ti y empieza a ahorrar en tu factura. Sin trucos, sin permanencia. Gestión 100% gratuita."
>
  <Header />
  <main class="min-h-screen">
    <Hero />
    <PricingSection />
    <OffersSection />
  </main>
  <Footer />
  <ContactModal />
  <ResultModal />
</Layout>
